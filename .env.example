# GEMINI_ATS_API_KEY: Google Gemini API key used ONLY for ATS resume scoring (server/utils/atsEngine.ts).
GEMINI_ATS_API_KEY=
# Optional model override for ATS (default: gemini-2.0-flash)
# GEMINI_ATS_MODEL=gemini-2.0-flash

# OPENROUTER_API_KEY: AI profile consultation and other non-ATS features.
OPENROUTER_API_KEY=

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# ==========================================
# PostgreSQL/Supabase Database (REQUIRED)
# ==========================================
# All data is stored ONLY in PostgreSQL via Supabase.
# SUPABASE_URL: Your Supabase project URL (REQUIRED)
# SUPABASE_SERVICE_ROLE_KEY or SUPABASE_ANON_KEY: Required for authentication (REQUIRED)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# ==========================================
# Database Initialization
# ==========================================
# Set RESET_DB_ON_START=true ONCE to wipe all tables and reseed with predefined login.
# WARNING: This deletes ALL data in PostgreSQL. Use with caution!
RESET_DB_ON_START=false

# Only one login will exist after seeding/reset.
PREDEFINED_LOGIN_EMAIL=campusconnectvsb@gmail.com
PREDEFINED_LOGIN_PASSWORD=123456
PREDEFINED_LOGIN_NAME="Campus Connect Admin"
PREDEFINED_LOGIN_ROLE=admin
PREDEFINED_LOGIN_ORG="CSB"

# TPO login credentials

# HR login credentials

# JWT Authentication Config
JWT_SECRET=

# Nodemailer / Gmail SMTP Configurations
GMAIL_USER=
GMAIL_APP_PASSWORD=

# Client/Server Cross-references
CLIENT_URL=http://localhost:3000
VITE_API_URL=http://localhost:3000

# Cloudinary (file uploads — resumes, documents)
# Option A: single URL from Cloudinary dashboard
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
# Option B: separate variables
# CLOUDINARY_CLOUD_NAME=your-cloud-name
# CLOUDINARY_API_KEY=your-api-key
# CLOUDINARY_API_SECRET=your-api-secret
