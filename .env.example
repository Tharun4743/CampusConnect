# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"
OPENROUTER_API_KEY=

# APP_URL: The URL where this applet is hosted.
APP_URL="MY_APP_URL"

# MongoDB Configurations
# DIRECT ATLAS VIEW LINK: https://cloud.mongodb.com/ (For cloud storage management)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.example.core.mongodb.net
MONGODB_DB_NAME=placement_portal

# JWT Authentication Config
JWT_SECRET=

# Nodemailer / Gmail SMTP Configurations
GMAIL_USER=
GMAIL_APP_PASSWORD=

# Client/Server Cross-references
CLIENT_URL=http://localhost:3000
VITE_API_URL=http://localhost:3000
