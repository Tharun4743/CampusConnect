# ==========================================
# Google Gemini API Configurations
# ==========================================
# GEMINI_ATS_API_KEY: Google Gemini API key used for ATS resume scoring (server/utils/atsEngine.ts).
GEMINI_ATS_API_KEY=
# GEMINI_ATS_MODEL: Model choice for ATS analysis (default: gemini-3.5-flash)
GEMINI_ATS_MODEL=gemini-3.5-flash

# ==========================================
# PostgreSQL / Supabase Configurations (REQUIRED)
# ==========================================
# SUPABASE_URL: Your Supabase project URL
SUPABASE_URL=https://your-project-ref.supabase.co
# SUPABASE_SERVICE_ROLE_KEY: Service role key for admin privileges
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
# SUPABASE_ANON_KEY: Anonymous public key
SUPABASE_ANON_KEY=your-supabase-anon-key

# ==========================================
# JWT Authentication Configurations
# ==========================================
# JWT_SECRET: Secret key for signing JSON Web Tokens
JWT_SECRET=your-jwt-session-secret-key-change-this-in-production

# ==========================================
# Nodemailer / SMTP Configurations
# ==========================================
# SMTP_HOST: Outgoing mail server host (e.g. smtp.gmail.com)
SMTP_HOST=smtp.gmail.com
# SMTP_PORT: Port number (e.g. 587 for TLS, 465 for SSL)
SMTP_PORT=587
# SMTP_USER: Username for auth (e.g. your-email@gmail.com)
SMTP_USER=
# SMTP_PASS: Password / App Password for SMTP auth
SMTP_PASS=
# SMTP_FROM: Default sender email address
SMTP_FROM=

# Fallback Legacy Email Configurations (Used if SMTP_* is not set)
GMAIL_USER=
GMAIL_APP_PASSWORD=

# ==========================================
# Cross-Reference URLs
# ==========================================
# APP_URL: The hosting URL where the Express backend app is located (used for Same-Origin check)
APP_URL=https://campus-connect.onrender.com
# CLIENT_URL: URL of the frontend client (for cookie path verification)
CLIENT_URL=https://campus-connect.onrender.com
# VITE_API_URL: API baseURL for Vite production build bundling (defaults to current host in browser)
VITE_API_URL=https://campus-connect.onrender.com

# ==========================================
# Cloudinary Configurations (Optional)
# ==========================================
# Option A: Single URL from Cloudinary dashboard
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
# Option B: Separate credentials
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ==========================================
# Predefined Seeding / Login Credentials
# ==========================================
PREDEFINED_LOGIN_EMAIL=campusconnectvsb@gmail.com
PREDEFINED_LOGIN_PASSWORD=12345678
PREDEFINED_LOGIN_NAME="Campus Connect Admin"
PREDEFINED_LOGIN_ROLE=admin
PREDEFINED_LOGIN_ORG="VSB"

# ==========================================
# Google Single Sign-On (OAuth 2.0)
# ==========================================
# GOOGLE_CLIENT_ID: Client ID from Google Cloud Console for backend validation.
GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
# VITE_GOOGLE_CLIENT_ID: Client ID for frontend GIS button rendering.
VITE_GOOGLE_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com

